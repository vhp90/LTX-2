# Auto-detect text files
* text=auto

# Binary files
*.mp4 binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.ico binary

# Large Weights (Git LFS)
*.safetensors binary filter=lfs diff=lfs merge=lfs -text
*.pt binary filter=lfs diff=lfs merge=lfs -text
*.pth binary filter=lfs diff=lfs merge=lfs -text
*.ckpt binary filter=lfs diff=lfs merge=lfs -text
*.bin binary filter=lfs diff=lfs merge=lfs -text
